# ============================================================
# 风控智能化平台 — 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# --- iv_meta MySQL 数据库（任务状态和指标结果查询）---
IV_META_HOST=10.1.20.59
IV_META_PORT=3306
IV_META_USER=your_user
IV_META_PASSWORD=your_password
IV_META_DB=iv_meta

# --- Doris 数据库（建表、SQL 衍生、数据查询）---
DORIS_HOST=10.1.19.245
DORIS_PORT=9030
DORIS_USER=your_user
DORIS_PASSWORD=your_password
DORIS_DB=sample_pool

# --- Metric Compute API ---
METRIC_API_URL=http://10.1.20.243:8200

# --- 特征中文名元数据（mysql_mcp 使用，与 IV_META 同一实例，默认可不填）---
# 默认库名：missing_rt_offline，表名：offline_metric_result
# 如需自定义，取消注释并填写
# FEATURE_META_DB=missing_rt_offline
# FEATURE_META_TABLE=offline_metric_result
